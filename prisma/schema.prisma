generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 공공시설/문화행사 정규화 데이터 — seed로 입력, 관리자 없음
model Place {
  id            String          @id @default(cuid())
  slug          String          @unique
  sourceType    PlaceSourceType
  sourceRef     String?         // 공공데이터 원본 ID
  name          String
  category      String          // culture | library | park | sports | welfare
  district      String?         // 서울 자치구 (예: "성동구")
  address       String?
  latitude      Float?
  longitude     Float?
  isFree        Boolean?
  feeText       String?
  openTimeText  String?         // "09:00"
  closeTimeText String?         // "18:00"
  homepageUrl   String?
  phone         String?
  description   String?
  travelHint    String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  cache         ExternalCache?
}

// 외부 API 응답 요약 캐시 — normalizedJson만 보관, raw response 금지
model ExternalCache {
  id             String      @id @default(cuid())
  placeId        String      @unique
  provider       String
  normalizedJson Json
  fetchedAt      DateTime
  expiresAt      DateTime
  status         CacheStatus @default(FRESH)
  place          Place       @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

// 추천 결과 스냅샷 캐시 — 동일 조건 재요청 시 재사용
model RecommendationSnapshot {
  id               String   @id @default(cuid())
  queryKey         String   @unique
  district         String?
  category         String?
  timeSlot         String?
  maxTravelMinutes Int
  resultJson       Json
  createdAt        DateTime @default(now())
  expiresAt        DateTime
}

enum PlaceSourceType {
  CULTURE_EVENT
  CULTURE_SPACE
  MOCK
}

enum CacheStatus {
  FRESH
  STALE
  ERROR
}
