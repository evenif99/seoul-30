DATABASE_URL=
SEOUL_OPEN_API_KEY=

# 배포 도메인 (sitemap, OG 절대 URL 생성에 사용)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# 지도 뷰: Leaflet + OpenStreetMap 사용 — 별도 API 키 불필요
# PUBLIC_DATA_SERVICE_KEY=   # 활용신청 완료 후 추가

USE_MOCK_DATA=true
ENABLE_REALTIME_CITY_DATA=false
ENABLE_CULTURE_EVENTS_API=false

# Phase 14 — Web Push (VAPID)
# 키 생성: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 브라우저 구독에 사용되는 공개 키 (NEXT_PUBLIC_ prefix 사용 가능)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Vercel Cron 보호용 시크릿 (임의 문자열)
CRON_SECRET=
