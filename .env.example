DATABASE_URL=
SEOUL_OPEN_API_KEY=

# Korea Tourism Organization TourAPI 4.0 (server-side only)
TOUR_API_KEY=

# 배포 도메인 (sitemap, OG 절대 URL 생성에 사용)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# 지도 뷰: Naver Maps JavaScript API v3
# NAVER Cloud Platform > Application 등록 후 Client ID 발급
# 허용 URL: http://localhost:3001, https://your-app.vercel.app
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=

USE_MOCK_DATA=true
ENABLE_REALTIME_CITY_DATA=false
ENABLE_CULTURE_EVENTS_API=false

# 스냅샷 캐시 TTL (초, 기본 7200 = 2시간)
# Seoul Open API 쿼터 절약 목적 — 호출 빈도 조정 시 사용
SNAPSHOT_TTL_SECONDS=7200

# 운영 대시보드 /admin 접근 제어 (선택)
# 미설정 시 /admin 공개, 설정 시 ?secret={값} 파라미터 필요
ADMIN_SECRET=

# Phase 14 — Web Push (VAPID)
# 키 생성: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 브라우저 구독에 사용되는 공개 키 (NEXT_PUBLIC_ prefix 사용 가능)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Vercel Cron 보호용 시크릿 (임의 문자열)
CRON_SECRET=
