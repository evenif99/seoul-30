DATABASE_URL=
SEOUL_OPEN_API_KEY=

# 배포 도메인 (sitemap, OG 절대 URL 생성에 사용)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Kakao Maps JS SDK 앱 키 (지도 뷰 활성화 — 없으면 지도 뷰 비활성 안내 표시)
# https://developers.kakao.com → 앱 추가 → 플랫폼 → Web → 사이트 도메인 등록 → JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=
# PUBLIC_DATA_SERVICE_KEY=   # 활용신청 완료 후 추가

USE_MOCK_DATA=true
ENABLE_REALTIME_CITY_DATA=false
ENABLE_CULTURE_EVENTS_API=false
