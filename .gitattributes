# Git line-ending normalization
# Prevents CRLF/LF mixed-encoding issues on Windows

# Source files — always LF in repo, checkout as-is
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf

# Markdown / docs — always LF
*.md   text eol=lf
*.mdx  text eol=lf

# Config files — always LF
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env  text eol=lf
.env*  text eol=lf

# Shell scripts — always LF (CRLF breaks sh/bash)
*.sh   text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
